    "@declaro/form-engine": "workspace:*",
    "@declaro/uniapp-shared": "workspace:*",
    "pinia": "^2.2.6",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@dcloudio/types": "3.4.31",
    "@dcloudio/uni-cli-shared": "3.0.0-alpha-5020120260706001",
    "@dcloudio/vite-plugin-uni": "3.0.0-alpha-5020120260706001",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.0.0",
    "happy-dom": "^15.11.0",
